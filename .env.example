# MongoDB Atlas connection string
# Get from your Atlas cluster: Connect > Drivers > Python
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Database name (will be created on first write)
MONGODB_DB=clairvoyance

# Years of history to backfill
BACKFILL_YEARS=5

# Logging
LOG_LEVEL=INFO
